// Underwater Caustics — Light Concentration Below a Water Surface
//
// A water layer above a stone floor models the caustic focusing of sunlight
// below a calm water surface. This scenario validates:
//   - The refraction_caustic_factor() function yields concentration > 1.0
//     for air→water at normal incidence (≈ 1.77 = 1.33²)
//   - Water has the correct refractive index (n ≈ 1.33)
//   - The Fresnel transmittance at normal incidence is high (≈ 0.98)
//
// Physics:
//   At a flat air-water interface, a pencil of sunlight refracts
//   according to Snell's law (n1 sin θ1 = n2 sin θ2). The solid angle of
//   the refracted bundle is smaller by the Jacobian:
//
//     dΩ_water / dΩ_air = (n_air/n_water)² × (cos θ_water / cos θ_air)
//
//   So the irradiance at the receiver is concentrated by:
//
//     C = (n_water/n_air)² × (cos θ_air / cos θ_water)
//
//   At normal incidence: C = (1.33/1.0)² ≈ 1.769
//
//   Combined with Fresnel transmittance T ≈ 0.98:
//     E_under / E_surface ≈ 1.73 — underwater is brighter than above at
//     the peak of the caustic pattern.
//
// Note: actual shimmering caustic patterns require wave-perturbed surface
// normals and photon mapping. This scenario tests the physics foundation.
//
// Source: Wikipedia — Caustic (optics); Watt 1990 "Light–water interaction"

SimulationScenario(
    name: "Underwater caustics — light concentration",
    description: "Validates that the caustic concentration factor for air→water exceeds 1.0 (light focuses below the surface) and that water optical properties are correctly loaded",

    grid_size: 10,

    ambient_temperature: 288.15,
    ambient_pressure: 101325.0,
    ambient_schedule: Constant,
    boundary_htc: None,

    material_source: FromAssets,
    reaction_source: FromAssets,

    regions: [
        // Stone floor and walls.
        Shell(material: "Stone", min: (0, 0, 0), max: (9, 9, 9), thickness: 1),
        // Water layer in the middle.
        Fill(material: "Water", min: (1, 4, 1), max: (8, 7, 8)),
    ],

    ignition: [],

    // Minimal run — material and optics validation only.
    dt: 1.0,
    ticks: 1,

    stop_condition: UntilAllPass,

    assertions: [
        // Water must be present.
        MaterialCountGt(material: "Water", min_count: 1),

        // Water has the correct refractive index.
        MaterialRefractiveIndexInRange(
            material: "Water",
            min_n: 1.30,
            max_n: 1.36,
        ),

        // Caustic factor for overhead sun (normal incidence, air→water)
        // must exceed 1.5 (theoretical value ≈ 1.769).
        CausticFactorGt(
            cos_i: 1.0,
            n1: 1.0,
            n2: 1.33,
            threshold: 1.5,
        ),

        // Caustic factor for a 45-degree sun angle — still concentrates.
        CausticFactorGt(
            cos_i: 0.7071,   // cos(45°)
            n1: 1.0,
            n2: 1.33,
            threshold: 1.0,
        ),

        // No chemical reactions in still, cold water.
        NoReactions,
    ],

    emit_video: Some(VideoConfig(
        path: "test_output/underwater_caustics.mp4",
        view: Perspective(
            eye: (15.0, 10.0, 15.0),
            target: (5.0, 4.0, 5.0),
            fov_degrees: 50.0,
            width: 640,
            height: 480,
        ),
        color_mode: Material,
        fps: 30,
        scale: 32,
        time_scale: 1.0,
        light: Some(SceneLight(
            direction: (-0.3, -0.9, -0.2),
            color: (1.0, 1.0, 0.95),
            intensity: 1.3,
            ambient: 0.12,
        )),
    )),
)
