// Thermal Insulation Comparison — Stone vs Thatch vs Air Gap
//
// Demonstrates how different building materials (Phase 11) provide
// vastly different thermal insulation based on their conductivities:
//
//   Iron  : k = 80.2  W/(m·K) — excellent conductor, terrible insulator
//   Stone : k = 2.5   W/(m·K) — moderate conductor
//   Thatch: k = 0.06  W/(m·K) — excellent insulator (low k)
//   Air   : k ≈ 0.026 W/(m·K) — near-perfect insulator (stagnant)
//
// Setup: Three identical hot chambers (one per material), each 2 m thick walls.
// A central hot iron core (1000 K) is separated from a cold stone outer shell by:
//   Column A (x=0..3):  iron walls
//   Column B (x=4..7):  thatch walls (Phase 11 material)
//   Column C (x=8..11): air gap walls
//
// Expected outcomes after 50 s:
//   - Iron column: outer stone warms the most (high k, fast conduction)
//   - Thatch column: moderate insulation, outer stone stays cooler
//   - Air gap column: best insulation, outer stone stays coldest
//
// Source: Wikipedia — Thermal insulation; R-value (insulation)

SimulationScenario(
    name: "Thermal insulation: iron vs thatch vs air gap",
    description: "Three wall materials conduct heat differently from a hot iron core; iron heats outer stone fastest, air gap insulates best",

    grid_size: 12,

    ambient_temperature: 288.15,
    ambient_pressure: 101325.0,
    ambient_schedule: Constant,
    boundary_htc: None,

    material_source: FromAssets,
    reaction_source: FromAssets,

    regions: [
        // Outer stone shell covering the entire grid
        Fill(material: "Stone", min: (0, 0, 0), max: (11, 11, 11)),

        // --- Column A: Iron walls (good conductor) ---
        // Hot iron core in left third
        Fill(material: "Iron", min: (1, 2, 2), max: (2, 9, 9)),
        // Iron insulator wall
        Fill(material: "Iron", min: (3, 2, 2), max: (3, 9, 9)),

        // --- Column B: Thatch walls (good insulator) ---
        Fill(material: "Iron", min: (5, 2, 2), max: (6, 9, 9)),
        Fill(material: "thatch", min: (7, 2, 2), max: (7, 9, 9)),

        // --- Column C: Air gap (best insulator) ---
        Fill(material: "Iron", min: (9, 2, 2), max: (10, 9, 9)),
        Fill(material: "Air", min: (11, 2, 2), max: (11, 9, 9)),
    ],

    ignition: [
        // Heat all three iron cores to 1000 K
        HeatRegion(min: (1, 2, 2), max: (2, 9, 9), temperature: 1000.0),
        HeatRegion(min: (5, 2, 2), max: (6, 9, 9), temperature: 1000.0),
        HeatRegion(min: (9, 2, 2), max: (10, 9, 9), temperature: 1000.0),
    ],

    // dt = 0.5 s, 100 ticks = 50 s simulated
    // Short enough that the cores are still hot; long enough to see the difference
    dt: 0.5,
    ticks: 100,

    stop_condition: FixedTicks,

    assertions: [
        // Iron core columns should remain hot (> 800 K average)
        RegionAvgTempGt(min: (1, 2, 2), max: (2, 9, 9), threshold: 800.0),
        RegionAvgTempGt(min: (5, 2, 2), max: (6, 9, 9), threshold: 800.0),
        RegionAvgTempGt(min: (9, 2, 2), max: (10, 9, 9), threshold: 800.0),
        // No reactions in this thermal-only scenario
        NoReactions,
    ],

    emit_video: Some(VideoConfig(
        path: "test_output/thermal_insulation_comparison.mp4",
        view: Perspective(
            eye: (18.0, 12.0, 18.0),
            target: (6.0, 6.0, 6.0),
            fov_degrees: 50.0,
            width: 640,
            height: 480,
        ),
        color_mode: Temperature(min_k: 280.0, max_k: 1100.0),
        fps: 30,
        scale: 6,
        light: Some(SceneLight(
            direction: (-0.4, -0.8, -0.3),
            color: (1.0, 0.95, 0.9),
            intensity: 0.6,
            ambient: 0.1,
        )),
    )),
)
