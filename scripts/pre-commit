#!/usr/bin/env bash
# Pre-commit hook for The Dark Candle
# Runs formatting check, linting, and tests before allowing a commit.
#
# Install: ./scripts/install-hooks.sh

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}[pre-commit]${NC} Running checks..."

# 1. Format check
echo -e "${YELLOW}[1/3]${NC} cargo fmt --check"
if ! cargo fmt --check 2>&1; then
    echo -e "${RED}✗ Formatting issues found. Run 'cargo fmt' to fix.${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ Formatting OK${NC}"

# 2. Clippy lint
echo -e "${YELLOW}[2/3]${NC} cargo clippy"
if ! cargo clippy --all-targets -- -D warnings 2>&1; then
    echo -e "${RED}✗ Clippy warnings found. Fix them before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ Clippy OK${NC}"

# 3. Tests
echo -e "${YELLOW}[3/3]${NC} cargo test"
if ! cargo test 2>&1; then
    echo -e "${RED}✗ Tests failed.${NC}"
    exit 1
fi
echo -e "${GREEN}  ✓ Tests OK${NC}"

echo -e "${GREEN}[pre-commit] All checks passed.${NC}"
